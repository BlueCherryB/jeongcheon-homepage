# Browser-safe Sanity values. These may be exposed in client bundles.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SANITY_PROJECT_ID=20zyfjea
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19

# Server-only. Never prefix this with NEXT_PUBLIC_ and never commit a real token.
# Published public-dataset reads should not require a token.
# Reserve this for future preview and draft reads from server-only code.
SANITY_API_READ_TOKEN=

# Server-only shared secret used by the Sanity webhook revalidation route.
SANITY_REVALIDATE_SECRET=

# Local secrets belong in .env.local or .dev.vars, which must not be committed.
# Add the same variable names in Cloudflare Workers build variables and runtime secrets.

# Required only for local/CI Cloudflare deployment commands. Do not expose these to the browser.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
